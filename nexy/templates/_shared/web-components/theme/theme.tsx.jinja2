    const container = document.getElementById("theme-container");
    if (!container) return;
    const el = container.querySelector(`[data-mode="${active.value}"]`) as HTMLElement;
    if (el) {
      const root = document.documentElement;
      root.style.setProperty("--spacing-slider-left", `${el.offsetLeft}px`);
      root.style.setProperty("--spacing-slider-width", `${el.offsetWidth}px`);
